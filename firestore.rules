rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ---------- Users ----------
    match /users/{userId} {
      allow read: if isSignedIn();
      // Crear: solo el propio usuario, sin auto-asignarse rol admin desde el cliente
      allow create: if isSelf(userId)
        && request.resource.data.role in ['member', 'admin'];
      // Actualizar:
      //   - El propio usuario puede tocar su perfil, stats, currentBalance e
      //     initialBalance(s) — los saldos iniciales por casa son
      //     configurables por cada usuario desde el dashboard.
      //     PERO no puede cambiar su rol.
      //   - El admin puede hacer cualquier cambio.
      allow update: if (isSelf(userId)
                        && request.resource.data.role == resource.data.role)
                     || isAdmin();
      allow delete: if isAdmin();
    }

    // ---------- Bets ----------
    match /bets/{betId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    // ---------- Matches / Teams / Groups (solo admin escribe) ----------
    match /matches/{id}      { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /teams/{id}        { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /groups/{id}       { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /playerStats/{id}  { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /thirdPlaceTable/{id} { allow read: if isSignedIn(); allow write: if false; }
    match /rankings/{id}     { allow read: if isSignedIn(); allow write: if false; }

    // Movimiento de posición del ranking, por grupo. Lo mantiene el cliente de
    // cualquier miembro que abra la clasificación (recalcula la posición de
    // todos y registra quién sube/baja). Dato no sensible (solo posiciones),
    // así que lectura/escritura para cualquier usuario autenticado.
    match /rankMovements/{groupId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ---------- Predictions ----------
    match /predictions/{userId} {
      allow read: if isSignedIn();
      allow write: if isSelf(userId)
        && (!('lockedAt' in resource.data) || resource.data.lockedAt > request.time);
    }

    // ---------- Achievements ----------
    match /achievements/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /userAchievements/{userId}/{achId} {
      allow read: if isSignedIn();
      allow write: if false; // solo Cloud Functions
    }

    // ---------- Feed ----------
    match /feed/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn(); // reacciones
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      }
    }

    // ---------- Suggestions (buzón de sugerencias) ----------
    match /suggestions/{id} {
      allow read: if isSignedIn();
      // Crear: cualquier usuario autenticado, siempre como autor de su propia
      // sugerencia y arrancando sin marcar como hecha.
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.done == false;
      // Actualizar:
      //   - Admin: cualquier cambio (incluye marcar/desmarcar "done").
      //   - Autor (no admin): puede editar su sugerencia PERO no cambiar el
      //     campo `done`, ni la autoría, ni la fecha de creación. Así solo los
      //     admins pueden marcar una sugerencia como hecha.
      allow update: if isAdmin()
        || (isSignedIn()
            && resource.data.userId == request.auth.uid
            && request.resource.data.userId == resource.data.userId
            && request.resource.data.done == resource.data.done
            && request.resource.data.createdAt == resource.data.createdAt);
      // Eliminar: el autor su propia sugerencia, o un admin cualquiera.
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // ---------- Seasons / Audit ----------
    match /seasons/{id}   { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /auditLog/{id}  { allow read: if isAdmin();   allow write: if false; }
  }
}
